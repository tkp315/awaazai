    "start": "cross-env NODE_ENV=prod node dist/server.js",
    "start:prod": "npm run build && npm run start",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet\" && exit 0",
