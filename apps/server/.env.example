# =========================================
# APP
# =========================================
NODE_ENV=development
PORT=5000

# =========================================
# MongoDB
# =========================================
MONGO_URL=
MONGO_DB_NAME=

# Pool settings
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2

# Retry settings
MONGO_MAX_RETRY=5
MONGO_TIMEOUT=30

# =========================================
# Redis
# =========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Production example (AWS ElastiCache)
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=

# =========================================
# JWT
# =========================================
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES=7d

# =========================================
# AWS
# =========================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =========================================
# S3
# =========================================
AWS_S3_BUCKET=
AWS_S3_AUDIO_BUCKET=

# =========================================
# PostgreSQL / Supabase
# =========================================
SUPABASE_DB_PASSWORD=
DATABASE_URL=
# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=awaazai
