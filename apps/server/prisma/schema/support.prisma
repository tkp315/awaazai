// AwaazAI Database Schema - Support Module
// Tables: SupportTicket, Feedback

model SupportTicket {
  id          String         @id @default(uuid())
  subject     String
  description String
  category    TicketCategory
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  resolvedAt  DateTime?
  closedAt    DateTime?

  // User Relation (who created ticket)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Assigned Admin (nullable)
  assignedToId String?
  assignedTo   User?  @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([category])
}

model Feedback {
  id      String       @id @default(uuid())
  type    FeedbackType
  rating  Int          // 1-5
  comment String?

  // User Relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional: Specific resource feedback
  voiceId String? // FK to Voice/BotVoice if rating voice
  botId   String? // FK to Bot if rating bot
  chatId  String? // FK to Chat if rating chat experience

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([rating])
}
